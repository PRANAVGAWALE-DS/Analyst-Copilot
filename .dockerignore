docs/
*.md

# ── Data (mounted as volumes at runtime — never bake into the image) ──────────
data/
logs/
*.log

# ── Compose / CI config (not needed inside the image) ────────────────────────
docker-compose*.yml
.github/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

