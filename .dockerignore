# ── Git ───────────────────────────────────────────────────────────────────────
.git
.github
.gitignore
.gitattributes

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
venv_ANALYST_COPILOT/

