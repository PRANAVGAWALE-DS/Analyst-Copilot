# .env — local development configuration.
# NEVER commit this file. It is listed in .gitignore.
# Copy .env.example to .env and fill in real values.

# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# ── Authentication ────────────────────────────────────────────────────────────
# Leave blank to disable auth for local dev.
# Set a strong random string for any shared or production environment.
API_KEY=

# ── LLM ───────────────────────────────────────────────────────────────────────
# Supported providers: groq | gemini
LLM_PROVIDER=groq

# Fill in your real key — server will NOT start if this is blank and LLM_PROVIDER=groq.
GROQ_API_KEY=

# Only required when LLM_PROVIDER=gemini.
GEMINI_API_KEY=

# Use llama-3.3-70b-versatile for best SQL generation quality.
# llama-3.1-8b-instant is much smaller and produces lower-quality SQL — avoid it.
LLM_MODEL=llama-3.3-70b-versatile

# ── Database ──────────────────────────────────────────────────────────────────
# The database the copilot runs queries against (read-only).
# Generate test data first: python scripts/synthetic_data.py --output data/insurance.db
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/analyst_copilot

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# BAAI/bge-large-en-v1.5 outputs 1024-dimensional vectors (BERT-large architecture).
# bge-BASE-en-v1.5 outputs 768 dims — do not confuse the two.
# app.py reads this and passes it to FAISSIndexer AND LongTermMemory:
#   FAISSIndexer(dimension=int(EMBEDDING_DIM))
#   LongTermMemory(dimension=int(EMBEDDING_DIM))
# If you change EMBEDDING_MODEL, update this value to match the new model output dim.
# Wrong value → FAISS assertion error on first embed add() call.
EMBEDDING_DIM=1024

EMBEDDING_BATCH_SIZE=64

# ── FAISS ─────────────────────────────────────────────────────────────────────
# Directory for FAISS index files (.faiss, .meta) and the embed cache.
# The consolidated embed cache path is data/faiss_index/embed_cache.json.
# Note: app.py uses FAISS_INDEX_DIR for both SchemaEmbedder cache and FAISSIndexer
# index storage. FAISS_INDEX_PATH (file-level path) is not read by app.py.
FAISS_INDEX_DIR=data/faiss_index

# ── Session store ─────────────────────────────────────────────────────────────
# Falls back to in-memory if blank or unreachable (sessions lost on restart).
REDIS_URL=

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated CORS origins. Leave blank to disable CORS entirely.
ALLOWED_ORIGINS=http://localhost:3000

# Comma-separated allowlist of database hosts accepted by /ingest.
# Restricts which databases the server will connect to (SSRF protection).
# After the H4 fix, localhost and 127.0.0.1 are canonicalised to the same
# entry before the check — listing both is redundant. 127.0.0.1 removed.
ALLOWED_DB_HOSTS=host.docker.internal,localhost

# H4 FIX (new): SQLite /ingest requests are restricted to paths inside this
# directory. Prevents sqlite:///../../etc/passwd style path-traversal.
# Default is "data" if unset; set explicitly to document the boundary.
SQLITE_DATA_ROOT=data

# ── Docker / PostgreSQL ───────────────────────────────────────────────────────
# H7 FIX (new): required when running `docker compose --profile db up`.
# docker-compose.yml uses ${POSTGRES_PASSWORD:?...} which hard-fails if unset,
# preventing silent deployment with a default credential.
# Use a strong random value — minimum 32 characters recommended.
POSTGRES_PASSWORD=

# Optional overrides for the Postgres container (docker compose --profile db).
# Defaults match the docker-compose.yml values; only set if you change them.
# POSTGRES_USER=postgres
# POSTGRES_DB=analyst_copilot

# ── Phase 2: Pandas DataFrame loader ─────────────────────────────────────────
FILE_DATA_ROOT=data/files
DF_CACHE_TTL_SECONDS=300
DF_ROW_LIMIT=50000

# ── Phase 3: Long-term memory ─────────────────────────────────────────────────
LT_MEMORY_DIR=data/lt_memory
LT_MEMORY_K=3
